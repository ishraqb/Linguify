SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
# Must EXACTLY match a Redirect URI registered in your Spotify app settings.
# On Codio use your box URL, e.g. https://<YOUR-BOX>-5000.codio.io/api/callback
SPOTIFY_REDIRECT_URI=https://<YOUR-BOX>-5000.codio.io/api/callback
# Frontend origin the backend redirects to after login.
FRONTEND_URL=https://<YOUR-BOX>-5173.codio.io
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_long_random_string
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false